{
  "name": "mall-nest-service",
  "version": "1.0.0",
  "description": "NestJS 微服务架构 - 商城后端服务",
  "scripts": {
    "install:all": "npm install && npm run install:apps",
    "install:apps": "cd apps/gateway && npm install && cd ../auth && npm install && cd ../system && npm install && cd ../order && npm install && cd ../stock && npm install && cd ../upload && npm install && cd ../cart && npm install && cd ../pay && npm install",
    "dev:gateway": "cd apps/gateway && npm run start:dev",
    "dev:auth": "cd apps/auth && npm run start:dev",
    "dev:system": "cd apps/system && npm run start:dev",
    "dev:order": "cd apps/order && npm run start:dev",
    "dev:stock": "cd apps/stock && npm run start:dev",
    "dev:upload": "cd apps/upload && npm run start:dev",
    "dev:cart": "cd apps/cart && npm run start:dev",
    "dev:pay": "cd apps/pay && npm run start:dev",
    "build:all": "cd apps/gateway && npm run build && cd ../auth && npm run build && cd ../system && npm run build && cd ../order && npm run build && cd ../stock && npm run build && cd ../upload && npm run build && cd ../cart && npm run build && cd ../pay && npm run build"
  },
  "keywords": ["nestjs", "microservice", "mall"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@prisma/client": "^5.0.0",
    "prisma": "^5.0.0",
    "redis": "^4.6.0",
    "ioredis": "^5.3.0",
    "nacos": "^2.2.0",
    "rocketmq-client-nodejs": "^1.0.0",
    "bcrypt": "^5.1.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0",
    "@types/bcrypt": "^5.0.0"
  }
}
